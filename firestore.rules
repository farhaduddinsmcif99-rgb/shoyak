rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users can't list other users
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('role' in data) || (data.role in ['user', 'admin']))
        && (!('farmData' in data) || data.farmData is map);
    }

    // Jobs Rules
    match /jobs/{jobId} {
      allow read: if true; // Public listings
      allow write: if isSignedIn(); // Simplified for now, should ideally be limited to employers
    }

    // Applications Rules
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (isOwner(incoming().userId) || isOwner(existing().userId));
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(incoming().jobId);
    }

    // Scam Reports Rules
    match /scamReports/{reportId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(incoming().userId);
    }
  }
}
